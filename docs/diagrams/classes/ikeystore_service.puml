@startuml ikeystore_service_class
title IKeystoreService Interface - Class Diagram

skinparam classAttributeIconSize 0
skinparam linetype ortho

interface "IKeystoreService" as IKey {
    +virtual ~IKeystoreService() = 0
    
    +virtual Status init() = 0
    +virtual Status deinit() = 0
    
    +virtual Status importKey(uint8_t keySlotId,
                             Algorithm algorithm,
                             span<const uint8_t> keyData,
                             uint8_t permissions) = 0
    
    +virtual Status deleteKey(uint8_t keySlotId) = 0
    
    +virtual Status getKey(uint8_t keySlotId, Key& key) = 0
    
    +virtual Status getSlotInfo(uint8_t keySlotId,
                               KeySlotInfo& info) = 0
    
    +virtual Status clearAll() = 0
    
    +virtual bool isSlotOccupied(uint8_t keySlotId) const = 0
}

note right of IKey
  **Purpose:** Secure key storage interface
  
  **Responsibilities:**
  - Key import with permissions
  - Secure key retrieval
  - Key deletion (secure erase)
  - Slot management
  
  **Security:**
  - Keys stored in secure memory
  - Secure clear on deletion
  - Permission-based access
  
  **Location:** include/ikeystore_service.hpp
end note

IKey ..> Status : returns
IKey ..> Algorithm : uses
IKey ..> Key : uses
IKey ..> KeySlotInfo : uses

@enduml
